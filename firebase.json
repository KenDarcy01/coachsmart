{
  "hosting": [
    {
      "target": "main",
      "public": "website",
      "ignore": ["firebase.json", "**/.*"],
      "headers": [
        {
          "source": "/webviews/**",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
            { "key": "Pragma", "value": "no-cache" },
            { "key": "Expires", "value": "0" }
          ]
        }
      ]
    },
    {
      "target": "website-alt",
      "public": "website-alt",
      "ignore": ["firebase.json", "**/.*"]
    }
  ]
}
